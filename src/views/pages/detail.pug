extends ../layout
block content
	.container
		.row
			.col-md-5
				if book.cover && book.cover.indexOf('https:') > -1
					img(src=`${book.cover}`,alt=`${book.name}`,width="70%",height="70%")
				else
					img(src=`/upload/${book.cover}`,alt=`${book.title}`,width="70%",height="70%")
			.col-md-7
				dl.row
					dt.col-sm-3 书名
					dd.col-sm-9= book.title
					dt.col-sm-3 作者
					dd.col-sm-9= book.author
					dt.col-sm-3 出版社
					dd.col-sm-9= book.publisher
					dt.col-sm-3 出版年代
					dd.col-sm-9= book.year
					dt.col-sm-3 定价
					dd.col-sm-9= book.price
					dt.col-sm-3 ISBN
					dd.col-sm-9= book.isbn
					dt.col-sm-3 内容详情
					dd.col-sm-9= book.summary
				.card
					.card-header
						h3 评论区
					.card-body
						each item in comments
							.d-flex.mb-3
								.me-3
									a.comment(href="#comments", data-cid=`${item._id}`, data-tid=`${item.from._id}`)
										img(src="data:image/svg+xml;base64,", style="width: 64px; height: 64px;")
								.flex-grow-1
									h4 #{item.from.name}
									p #{item.content}
									if item.reply && item.reply.length > 0
										each reply in item.reply
											.d-flex.mb-2
												.me-3
													a.comment(href="#comments", data-cid=`${item._id}`, data-tid=`${reply.from._id}`)
														img(src="data:image/svg+xml;base64,", style="width: 64px; height: 64px;")
												.flex-grow-1
													h4
														| #{reply.from.name}
														span.text-info &nbsp;回复&nbsp;
														| #{reply.to.name}:
													p #{reply.content}
							hr
						#comments
							form#commentForm(method="POST", action="/user/comment")
								input(type="hidden", name="_csrf", value=csrfToken)
								input(type="hidden", name="comment[book]", value=`${book._id}`)
								if user
									input(type="hidden", name="comment[from]", value=`${user._id}`)
								.mb-3
									textarea.form-control(name="comment[content]", rows="3")
								if user
									button.btn.btn-primary(type='submit') 提交
								else
									a.navbar-link(href="#", data-bs-toggle="modal", data-bs-target="#signinModal") 登录后评论
	script(src="/js/detail.js")
