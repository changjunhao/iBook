# iBook 应用配置
# 复制此文件为 .env 并修改其中的值

# 运行环境：development | production | test
NODE_ENV=development

# 服务端口
PORT=3000

# MongoDB 连接地址
MONGO_URL=mongodb://127.0.0.1:27017/iBook

# Session 加密密钥（生产环境请务必修改为随机字符串）
SESSION_SECRET=iBook-dev-secret-change-in-production

# Session 配置
SESSION_RESAVE=true
SESSION_SAVE_UNINITIALIZED=true

# Morgan 日志格式：dev | combined | common | short | tiny
MORGAN_FORMAT=dev
